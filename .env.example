# WAHA MCP Server Configuration

# WAHA instance URL (default: http://localhost:3001)
WAHA_URL=http://localhost:3001

# WAHA API Key (REQUIRED)
WAHA_API_KEY=your-api-key-here

# Soniox Speech-to-Text API key (optional — enables voice message transcription
# in waha_get_chat_context and waha_transcribe_message; get one at https://soniox.com)
# SONIOX_API_KEY=your-soniox-key

# HTTP timeout for WAHA requests in milliseconds (optional, default 30000)
# WAHA_TIMEOUT_MS=30000

# Default session name (optional). If set, every tool's `session` param
# defaults to it. If NOT set, `session` becomes REQUIRED on every tool call —
# the safe choice when multiple WhatsApp accounts are connected.
# WAHA_DEFAULT_SESSION=default

# Anti-ban send throttle (optional, OFF by default). Set to 1 to enable
# pacing: 3-8s jitter between sends, max 8/min, group ops spaced 120s.
# WAHA_THROTTLE=1

# ---------------------------------------------------------------------------
# Telegram MCP server (dist/telegram/index.js) — MTProto user account
# ---------------------------------------------------------------------------

# API credentials from https://my.telegram.org → "API development tools"
# (create an app once; these identify the app, not the account).
# TELEGRAM_API_ID=123456
# TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef

# gramjs StringSession — generated by `npm run telegram:login` (one-time
# interactive sign-in: phone → code → optional 2FA). TREAT LIKE A PASSWORD:
# it grants full access to the Telegram account.
# TELEGRAM_SESSION=...
